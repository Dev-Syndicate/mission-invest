rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Vision board images — user can upload/read own files
    match /visionImages/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // max 5MB
        && request.resource.contentType.matches('image/.*');
    }

    // Certificates — user can read own, Cloud Functions can write
    match /certificates/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Cloud Functions via Admin SDK only
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
